rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /teams/{teamId} {
      allow read: if true;

      allow create, update: if
        request.resource.data.teamNumber is int &&
        request.resource.data.teamNumber >= 1 &&
        request.resource.data.teamNumber <= 10 &&
        request.resource.data.step is int &&
        request.resource.data.step >= 1 &&
        request.resource.data.step <= 9 &&
        (!('visitedStep32' in request.resource.data) ||
          request.resource.data.visitedStep32 is bool) &&
        (!('deskTaskStatus' in request.resource.data) ||
          (
            (request.resource.data.deskTaskStatus == 'idle' ||
              request.resource.data.deskTaskStatus == 'pending' ||
              request.resource.data.deskTaskStatus == 'done') &&
            request.resource.data.deskTaskStep is int &&
            request.resource.data.deskTaskStep >= 1 &&
            request.resource.data.deskTaskStep <= 9 &&
            request.resource.data.deskTaskRevision is int &&
            request.resource.data.deskTaskRevision >= 1 &&
            request.resource.data.deskTaskRequestedBy is string &&
            (!('deskTaskInstruction' in request.resource.data) ||
              request.resource.data.deskTaskInstruction is string) &&
            (!('deskTaskCompletedSteps' in request.resource.data) ||
              request.resource.data.deskTaskCompletedSteps is list)
          ));
    }
  }
}
